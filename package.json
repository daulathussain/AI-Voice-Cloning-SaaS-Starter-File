{
  "name": "voiceads-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",

    "api:start": "node scripts/start-api.js",

    "api:health": "node -e \"const http=require('http'); const req=http.get('http://localhost:8000/health',res=>{let d='';res.on('data',c=>d+=c);res.on('end',()=>{try{const j=JSON.parse(d);console.log(JSON.stringify(j,null,2))}catch{console.log(d)}})}); req.on('error',()=>console.log('❌ API not running — start with: npm run api:start'))\"",

    "dev:full": "node -e \"const {spawn}=require('child_process'); const api=spawn('npm',['run','api:start'],{stdio:'inherit',shell:true}); const web=spawn('npm',['run','dev'],{stdio:'inherit',shell:true}); const cleanup=()=>{api.kill();web.kill();process.exit()}; process.on('SIGINT',cleanup); process.on('SIGTERM',cleanup)\"",

    "clean": "npm run clean:modules && npm run clean:python && npm run clean:next",
    "clean:modules": "node -e \"const fs=require('fs'); if(fs.existsSync('node_modules')){fs.rmSync('node_modules',{recursive:true});console.log('✅ Deleted node_modules')}\"",
    "clean:python": "node -e \"const fs=require('fs'); if(fs.existsSync('python-api/venv')){fs.rmSync('python-api/venv',{recursive:true});console.log('✅ Deleted python-api/venv')}\"",
    "clean:next": "node -e \"const fs=require('fs'); ['.next','out'].forEach(p=>{if(fs.existsSync(p)){fs.rmSync(p,{recursive:true});console.log('✅ Deleted',p)}})\"",
    "reinstall": "npm run clean && npm install --legacy-peer-deps && node scripts/setup-python.js",
    "install:python": "node scripts/setup-python.js"
  },
  "dependencies": {
    "next": "15.3.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@supabase/supabase-js": "2.44.4",
    "@supabase/ssr": "0.3.0",
    "tailwindcss": "3.4.4",
    "framer-motion": "12.15.0",
    "zustand": "4.5.4",
    "react-hook-form": "7.52.1",
    "zod": "3.23.8",
    "@hookform/resolvers": "3.6.0",
    "lucide-react": "0.395.0",
    "recharts": "2.12.7",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "tailwind-merge": "2.3.0",
    "stripe": "15.12.0",
    "@stripe/stripe-js": "3.5.0",
    "wavesurfer.js": "7.7.15",
    "react-dropzone": "14.2.3",
    "sonner": "1.5.0",
    "date-fns": "3.6.0",
    "axios": "1.7.2",
    "@radix-ui/react-dialog": "1.1.1",
    "@radix-ui/react-dropdown-menu": "2.1.1",
    "@radix-ui/react-select": "2.1.1",
    "@radix-ui/react-slider": "1.2.0",
    "@radix-ui/react-tabs": "1.1.0",
    "@radix-ui/react-tooltip": "1.1.2",
    "@radix-ui/react-progress": "1.1.0",
    "@radix-ui/react-avatar": "1.1.0",
    "@radix-ui/react-checkbox": "1.1.1",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-separator": "1.1.0",
    "@radix-ui/react-switch": "1.1.0",
    "@radix-ui/react-alert-dialog": "1.1.1",
    "@radix-ui/react-scroll-area": "1.1.0",
    "@radix-ui/react-popover": "1.1.1",
    "@radix-ui/react-toast": "1.2.1"
  },
  "devDependencies": {
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5"
  }
}
